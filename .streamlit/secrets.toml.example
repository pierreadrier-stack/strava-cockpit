# ─────────────────────────────────────────────
#  secrets.toml.example  –  Modèle de secrets
# ─────────────────────────────────────────────
#  Copie ce fichier en .streamlit/secrets.toml pour le DEV LOCAL.
#  ⚠️ Ne JAMAIS committer secrets.toml (il est dans .gitignore).
#  En PROD : Streamlit Cloud → ton app → Settings → Secrets (colle le même contenu).

# Mot de passe d'accès à l'app
app_password = "change-moi"

# Coach IA (optionnel)
ANTHROPIC_API_KEY = "sk-ant-..."

# ── Connexion Strava en direct (optionnel) ──
#  Obtiens ces valeurs avec :  python scripts/get_strava_token.py
STRAVA_CLIENT_ID     = "12345"
STRAVA_CLIENT_SECRET = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRAVA_REFRESH_TOKEN = "yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"
